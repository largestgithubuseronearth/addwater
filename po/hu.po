#: data/gtk/preferences.ui:31
msgid ""
"Remove the theme from all known profiles and reset Add Water to its default "
"state. Any custom changes made to your user.js file will remain after a "
"reset."
msgstr ""
"A téma eltávolítása az összes ismert profilból, és az Egy csepp víz "
"visszaállítása az alapértelmezett állapotába. A user.js fájlban végzett "
"egyéni változtatások megmaradnak a visszaállítás után."

#: data/gtk/preferences.ui:34
msgid "Reset and Close App"
msgstr "Visszaállítás és alkalmazás bezárása"

