#: src/apps/firefox/firefox_options.py:5
msgid "Tab Position"
msgstr "Posição dos separadores"

#: src/apps/firefox/firefox_options.py:10
msgid "Hide Single Tab"
msgstr "Ocultar separador único"

#: src/apps/firefox/firefox_options.py:13
msgid ""
"Consider placing the New Tab button near the Search Bar. Otherwise it may "
"get lost when only one tab is open."
msgstr ""
"Considere colocar o botão de Novo Separador perto da barra de pesquisa. Caso "
"contrário, poderá perdê-lo de vista quando apenas um separador estiver "
"aberto."

#: src/apps/firefox/firefox_options.py:20
msgid "Standard Tab Width"
msgstr "Largura padrão dos separadores"

#: src/apps/firefox/firefox_options.py:21
msgid "Use same tab width as standard Firefox"
msgstr "Usar a mesma largura de separador do Firefox padrão"

#: src/apps/firefox/firefox_options.py:28
msgid "Swap Tab Close Button"
msgstr "Inverter botão de fechar separador"

#: src/apps/firefox/firefox_options.py:30
msgid "Place Close Tab button on opposite side from window controls"
msgstr ""
"Colocar o botão de fechar separador no lado oposto aos controlos da janela"

#: src/apps/firefox/firefox_options.py:38
msgid "Bookmarks Toolbar Under Tabs"
msgstr "Barra de marcadores sob os separadores"

#: src/apps/firefox/firefox_options.py:39
msgid "Place Bookmarks Bar underneath Tab Bar"
msgstr "Colocar a barra de marcadores por baixo da barra de separadores"

#: src/apps/firefox/firefox_options.py:46
msgid "Tabs as Headerbar"
msgstr "Separadores como barra de cabeçalho"

#: src/apps/firefox/firefox_options.py:47
msgid "Place Tab Bar at top of window"
msgstr "Colocar a barra de separadores no topo da janela"

#: src/apps/firefox/firefox_options.py:49
msgid ""
"Enabling with \"Hide Single Tab\" will show a Title Bar when only one tab is "
"open"
msgstr ""
"Ao ativar com \"Ocultar separador único\", será mostrada uma barra de título "
"quando apenas um separador estiver aberto"

#: src/apps/firefox/firefox_options.py:56
msgid "Left-Aligned Titles"
msgstr "Títulos alinhados à esquerda"

#: src/apps/firefox/firefox_options.py:57
msgid "Align tab title to left"
msgstr "Alinha o título do separador à esquerda"

#: src/apps/firefox/firefox_options.py:64
msgid "Tab Behavior"
msgstr "Comportamento dos separadores"

#: src/apps/firefox/firefox_options.py:69
msgid "Active Tab Contrast"
msgstr "Contraste do separador ativo"

#: src/apps/firefox/firefox_options.py:70
msgid "Add more visual contrast to the active tab"
msgstr "Adicionar mais contraste visual ao separador ativo"

#: src/apps/firefox/firefox_options.py:77
msgid "Close Only Selected Tabs"
msgstr "Fechar apenas separadores selecionados"

#: src/apps/firefox/firefox_options.py:78
msgid "Only show the Close Tab button on the active tab"
msgstr "Mostrar o botão de fechar apenas no separador ativo"

#: src/apps/firefox/firefox_options.py:85
msgid "Symbolic Tab Icons"
msgstr "Ícones de separador simbólicos"

#: src/apps/firefox/firefox_options.py:86
msgid "Make all tab icons appear similar to symbolic icons"
msgstr ""
"Fazer com que todos os ícones dos separadores pareçam ícones simbólicos"

#: src/apps/firefox/firefox_options.py:93
msgid "List of Tabs"
msgstr "Lista de separadores"

#: src/apps/firefox/firefox_options.py:94
msgid "Always show All Tabs button"
msgstr "Mostrar sempre o botão de Listar todos os separadores"

#: src/apps/firefox/firefox_options.py:101
msgid "List of Tabs on Overflow"
msgstr "Lista de separadores ao transbordar"

#: src/apps/firefox/firefox_options.py:102
msgid "Only show All Tabs button when many tabs are open"
msgstr ""
"Mostrar botão de Listar todos os separadores apenas quando muitos estiverem "
"abertos"

#: src/apps/firefox/firefox_options.py:114
msgid "Hide Privacy Indicators"
msgstr "Ocultar indicadores de privacidade"

#: src/apps/firefox/firefox_options.py:115
msgid "Hide microphone, screen share, and camera warnings"
msgstr "Ocultar avisos de microfone, partilha de ecrã e câmara"

#: src/apps/firefox/firefox_options.py:117
msgid "GNOME will still show these privacy indicators in the Top Bar"
msgstr ""
"O GNOME continuará a mostrar estes indicadores de privacidade na barra "
"superior"

#: src/apps/firefox/firefox_options.py:124
msgid "True Black Dark Theme"
msgstr "Tema escuro em preto puro"

#: src/apps/firefox/firefox_options.py:126
msgid "Use an OLED-friendly, deep black when dark theme is enabled"
msgstr ""
"Utilizar um preto profundo (ideal para OLED) quando o tema escuro estiver "
"ativo"

#: src/apps/firefox/firefox_options.py:134
msgid "No Themed Icons"
msgstr "Sem ícones temáticos"

#: src/apps/firefox/firefox_options.py:136
msgid "Use standard Firefox icons instead of Adwaita-styled icons"
msgstr "Usar ícones padrão do Firefox em vez dos ícones estilo Adwaita"

#: src/apps/firefox/firefox_options.py:144
msgid "Fullscreen Bookmarks"
msgstr "Marcadores em ecrã inteiro"

#: src/apps/firefox/firefox_options.py:145
msgid "Show Bookmarks bar while in fullscreen"
msgstr "Mostrar barra de marcadores em modo de ecrã inteiro"

#: src/gui/option_factory.py:93
msgid "More Information"
msgstr "Mais informações"

