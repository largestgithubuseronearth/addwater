<?xml version="1.0" encoding="UTF-8"?>
<interface>
<requires lib="gtk" version="4.0"/>
<requires lib="Adw" version="1.0"/>
	<template class="WaterWindow" parent="AdwApplicationWindow">
		<property name="default-width">500</property>
		<property name="default-height">800</property>
		<property name="title" translatable="no">Add Water</property>
		<property name="content">

				<object class="AdwToolbarView" id="main_toolbar_view">
					<!-- Header bar -->
					<child type="top">
						<object class="AdwHeaderBar" id="header_bar">
						  <property name="title-widget">
						    <!-- FIXME if this is hidden, then it should show normal title -->
						    <object class="AdwViewSwitcher" id="view_switcher">
						      <property name="policy">narrow</property>
						      <property name="stack">view_stack</property>
						    </object>
						  </property>
							<child type="end">
								<object class="GtkMenuButton" id="main_menu">
									<property name="primary">True</property>
									<property name="icon-name">open-menu-symbolic</property>
									<property name="tooltip-text" translatable="yes">Main Menu</property>
									<property name="menu-model">primary_menu</property>
								</object>
							</child>
						</object>
					</child>
				  <property name="content">
				    <object class="AdwViewStack" id="view_stack">
				      <!-- FirefoxPage is inserted by code -->
				      <child>
				        <!-- Error page -->
				        <object class="AdwViewStackPage">
				          <property name="name">error</property>
				          <property name="child">
				            <object class="AdwStatusPage" id="error_page"/>
				          </property>
				        </object>
				      </child>
				    </object>
				  </property>
				</object>

		</property>
	</template>

	<menu id="primary_menu">
		<section>
			<item>
				<attribute name="label" translatable="yes">_Preferences</attribute>
				<attribute name="action">win.preferences</attribute>
			</item>
			<item>
				<attribute name="label" translatable="yes">_Keyboard Shortcuts</attribute>
				<attribute name="action">app.shortcuts</attribute>
			</item>
			<item>
				<attribute name="label" translatable="yes">_About Add Water</attribute>
				<attribute name="action">win.about</attribute>
			</item>
		</section>
	</menu>
</interface>
